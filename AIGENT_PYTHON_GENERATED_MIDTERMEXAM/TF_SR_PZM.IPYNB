import control as ct
import matplotlib.pyplot as plt
import numpy as np

def analyze_system(num, den, title):

    sys = ct.TransferFunction(num, den)

    print("\n====================")
    print(f"System: {title}")
    print("====================")
    print("Transfer Function G(s):")
    print(sys)

    poles = ct.poles(sys)
    zeros = ct.zeros(sys)

    print("Poles:", poles)
    print("Zeros:", zeros)

    fig, (ax_step, ax_pz) = plt.subplots(1, 2, figsize=(14, 6))

    # Step Response
    t, y = ct.step_response(sys)
    ax_step.plot(t, y, linewidth=2)
    ax_step.set_title(f"Step Response - {title}")
    ax_step.set_xlabel("Time")
    ax_step.set_ylabel("Output")
    ax_step.grid(True)

    # Pole-Zero Map
    if poles.size > 0:
        ax_pz.scatter(np.real(poles), np.imag(poles), marker='x', s=100, label='Poles')

    if zeros.size > 0:
        ax_pz.scatter(np.real(zeros), np.imag(zeros), marker='o', s=100, facecolors='none', label='Zeros')

    ax_pz.axhline(0)
    ax_pz.axvline(0)
    ax_pz.set_title(f"Pole-Zero Map - {title}")
    ax_pz.set_xlabel("Real Axis")
    ax_pz.set_ylabel("Imaginary Axis")
    ax_pz.legend()
    ax_pz.grid(True)

    plt.tight_layout()
    plt.show()


# Equation 1
analyze_system([1, 1], [1, 4, 7, 6, 3], "Equation 1")

# Equation 2
analyze_system([1], [1, 2, 3, 2, 0], "Equation 2")

# Equation 3
analyze_system([4, 2, 6], [16, 24, 52, 36, 0], "Equation 3")
